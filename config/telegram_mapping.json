  "sofar_command_blok": {
    "_beschrijving": "Elke 5 P1-cycli (~5 seconden) schrijft BatMgmtV3.py een SOFAR COMMAND blok in het telegrambestand.",
    "formaat": "======== SOFAR COMMAND : <actie> ========\nMeasurement time : YYYY-MM-DD HH:MM:SS\n<vermogen in W>  ← alleen aanwezig bij laden/ontladen\n!",
    "acties": {
      "laden tot voorziene level":    "Batterij laden; vermogen in W staat op de volgende regel",
      "ontladen tot voorziene level": "Batterij ontladen; vermogen in W staat op de volgende regel",
      "laden door zon":               "Laden met zonne-overschot; vermogen in W staat op de volgende regel",
      "ontladen overschot":           "Ontladen om te vermijden dat stroom het net op gaat; vermogen in W",
      "stoppen":                      "Batterij in standby, geen vermogen op de volgende regel"
    },
    "besturingslogica": {
      "_beschrijving": "Drempelwaarden en beslisregels van BatMgmtV3.py",
      "MAX_GRID_POWER_KW":   3.5,
      "MAX_CHARGE_POWER_KW": 2.5,
      "MAX_BATTERY_SOC_PCT": 80,
      "MIN_BATTERY_SOC_PCT": 10,
      "net_power_formule":   "net_power = verbruik_kw - levering_kw - battery_power_kw",
      "regels": [
        { "conditie": "net_power < 3.5 AND soc < 80", "actie": "laden tot voorziene level",    "vermogen_kw": "min(2.5, 3.5 - net_power)" },
        { "conditie": "net_power > 3.5 AND soc > 10", "actie": "ontladen tot voorziene level", "vermogen_kw": "min(2.5, net_power - 3.5)" },
        { "conditie": "net_power < 0   AND soc < 100","actie": "laden door zon",               "vermogen_kw": "min(2.5, -net_power)" },
        { "conditie": "net_power > 0   AND soc > 80", "actie": "ontladen overschot",           "vermogen_kw": "min(2.5, net_power)" },
        { "conditie": "anders",                        "actie": "stoppen",                      "vermogen_kw": null }
      ]
    }
  }
