    "modbus_commando_registers": {
      "_beschrijving": "Schrijfregisters gebruikt door BatMgmtV3.py om de batterij aan te sturen (function code 0x42, heartbeat 0x49)",
      "0x0100": { "naam": "REG_STANDBY",   "waarde": "0x5555", "beschrijving": "Batterij in standby zetten (stoppen)" },
      "0x0101": { "naam": "REG_DISCHARGE", "waarde": "vermogen in W", "beschrijving": "Ontladen met opgegeven vermogen in W" },
      "0x0102": { "naam": "REG_CHARGE",    "waarde": "vermogen in W", "beschrijving": "Laden met opgegeven vermogen in W" },
      "0x2201": { "naam": "REG_HEARTBEAT", "waarde": "0x2202",        "beschrijving": "Heartbeat, na elk commando verplicht te sturen" }
    }
